---
import "@fontsource-variable/newsreader";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/600.css";
import "../styles/global.css";
import type { RegionData, HonestPlan } from "../lib/types";
import { pickByPreference } from "../lib/recommend";
import oncorRaw from "../data/oncor.json";
import manifestRaw from "../data/regions.json";

interface RegionMeta {
  slug: string; label: string; cities: string;
  counts: { total: number; honest: number; rejected: number };
}
const manifest = manifestRaw as unknown as { generated_at: string; regions: RegionMeta[] };
const data = oncorRaw as unknown as RegionData;

const DEFAULT_USAGE = 1000;
const pref0 = pickByPreference(data, DEFAULT_USAGE, "cheapest");
const pick = pref0 ? pref0.pick : null;
const pickPlan: HonestPlan | null = pick ? pick.plan : null;
const why0 = pref0 ? pref0.why : "";

const updated = new Date(manifest.generated_at).toLocaleDateString("en-US", {
  year: "numeric", month: "short", day: "numeric",
});
const oncorMeta = manifest.regions.find((r) => r.slug === "oncor")!;

const base = import.meta.env.BASE_URL;
const money = (n: number) => `$${n.toFixed(0)}`;
const centsAt = (bill: number, usage: number) => ((bill / usage) * 100).toFixed(1);
const shownAutopsies = data.autopsies.slice(0, 12);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Honest Texas Electricity — the honest cheapest plan, no affiliate links</title>
    <meta
      name="description"
      content="A free, no-affiliate tool that finds the honest cheapest Texas electricity plan. No provider pays us. We filter out bill-credit gimmicks and rank by your real cost."
    />
  </head>
  <body>
    <div class="wrap">
      <header class="masthead">
        <h1 class="brand">Honest <em>Texas</em> Electricity</h1>
      </header>

      <div class="trustline">
        <span>
          <strong>No affiliate links. No provider pays us. Ever.</strong>
          We rank the genuinely cheapest honest plan — even when it earns us nothing.
        </span>
        <span class="updated">Updated {updated}</span>
      </div>

      <section class="ask">
        <h2 class="ask-heading">Find your honest cheapest plan.</h2>
        <div class="fields">
          <div class="field field--zip">
            <label for="zip">Your ZIP code</label>
            <input id="zip" inputmode="numeric" maxlength="5" value="75201" aria-describedby="region-note" />
          </div>
          <div class="field field--region">
            <label for="region">Your utility area</label>
            <select id="region" aria-describedby="region-note">
              {manifest.regions.map((r) => (
                <option value={r.slug} selected={r.slug === "oncor"}>{r.label} — {r.cities.split(",")[0]}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="fields" style="margin-top:16px">
          <div class="field field--usage">
            <label for="usage">About how much power do you use?</label>
            <input
              id="usage" type="range" min="200" max="3000" step="50" value={DEFAULT_USAGE}
              aria-label="Monthly usage in kilowatt-hours"
            />
            <p class="usage-readout">
              <b id="usage-val">{DEFAULT_USAGE.toLocaleString()}</b> kWh / month · a typical Texas home
            </p>
          </div>
        </div>
        <p id="region-note" class="usage-readout" style="margin-top:8px">
          ZIP <strong>75201</strong> → showing <strong id="region-label">{oncorMeta.label}</strong>
          (<span id="region-cities">{oncorMeta.cities}</span>).
        </p>
      </section>

      <div class="pref-bar">
        <label for="pref">What matters most?</label>
        <select id="pref">
          <option value="cheapest" selected>Cheapest overall</option>
          <option value="renewable">100% renewable</option>
          <option value="shortest">Shortest commitment</option>
          <option value="lowcancel">Lowest cancel fee</option>
          <option value="rating">Best-rated provider</option>
        </select>
      </div>

      <p class="result-kicker" id="result-kicker">Your honest cheapest plan</p>
      <div id="result">
        {pickPlan && pick ? (
          <div class="plan-card">
            <div class="plan-card__top">
              <div class="plan-card__name">
                <span>{pickPlan.rep} — {pickPlan.product}</span>
                {pickPlan.efl_verified ? (
                  <span class="badge badge--verified">EFL-verified</span>
                ) : (
                  <span class="badge badge--estimate">feed estimate — verify EFL</span>
                )}
              </div>
              <div class="plan-card__rate">{centsAt(pick.monthlyBill, DEFAULT_USAGE)}&cent;<small>/ kWh</small></div>
            </div>
            <div class="facts">
              <div class="fact"><b>{money(pick.monthlyBill)}</b><span>est. bill</span></div>
              <div class="fact"><b>{pickPlan.rate_type} · {pickPlan.term_months ?? "—"} mo</b><span>rate &amp; term</span></div>
              <div class="fact"><b>{pickPlan.cancel_fee != null ? money(pickPlan.cancel_fee) : "—"}</b><span>cancel fee</span></div>
              <div class="fact"><b>{pickPlan.renewable != null ? `${pickPlan.renewable}%` : "—"}</b><span>renewable</span></div>
            </div>
            <p class="why">
              <strong>Why this won:</strong> {why0}
              {pickPlan.efl_url ? (<> <a href={pickPlan.efl_url} rel="nofollow noopener" target="_blank">See the official EFL →</a></>) : null}
            </p>
          </div>
        ) : (
          <div class="empty">No honest plan is available for this usage right now.</div>
        )}
      </div>

      <p class="see-all">
        <a id="see-all-link" href={`${base}plans/${data.slug}`}>
          See all <span id="honest-count">{data.counts.honest}</span> honest plans, sortable →
        </a>
        &nbsp;·&nbsp;
        <a href={`${base}overpaying`}>Am I overpaying? →</a>
        &nbsp;·&nbsp;
        <a href={`${base}trends`}>Track prices over time →</a>
      </p>

      <section class="rejected">
        <h2>Plans we threw out for you (<span id="rej-count">{data.counts.rejected}</span>)</h2>
        <div id="rej-list">
          {shownAutopsies.map((a) => (
            <div class="rej">
              <span class="x" aria-label="excluded">✕</span>
              <a class="pname pname-link" href={`${base}plan/${a.plan_id}`}>{a.rep} — {a.product}</a>
              <span class="reason">{a.verdicts[0]}</span>
            </div>
          ))}
          {data.counts.rejected > shownAutopsies.length && (
            <div class="rej">
              <span class="x">✕</span>
              <a class="pname pname-link" id="rej-more" href={`${base}rejected/${data.slug}`}>…and {data.counts.rejected - shownAutopsies.length} more</a>
              <span class="reason">see every rejected plan and why →</span>
            </div>
          )}
        </div>
      </section>

      <footer class="site-footer">
        A free public-interest tool. Data from the state's PowerToChoose, updated {updated}.
        Always verify a plan's official EFL before you enroll. We are not affiliated with
        any electricity provider and earn no referral fees.
      </footer>
    </div>

    <script type="application/json" id="region-data" set:html={JSON.stringify(data)}></script>
    <script type="application/json" id="region-manifest" set:html={JSON.stringify(manifest.regions)}></script>
    <script>
      import { pickByPreference, type Preference } from "../lib/recommend";
      import { zipToSlug } from "../lib/zipRegion";
      import type { RegionData } from "../lib/types";

      type Meta = { slug: string; label: string; cities: string };

      const regions = JSON.parse(
        document.getElementById("region-manifest")!.textContent!,
      ) as Meta[];
      let data = JSON.parse(
        document.getElementById("region-data")!.textContent!,
      ) as RegionData;
      let currentSlug = "oncor";
      const cache: Record<string, RegionData> = { oncor: data };

      const usage = document.getElementById("usage") as HTMLInputElement;
      const usageVal = document.getElementById("usage-val")!;
      const zip = document.getElementById("zip") as HTMLInputElement;
      const region = document.getElementById("region") as HTMLSelectElement;
      const pref = document.getElementById("pref") as HTMLSelectElement;
      const result = document.getElementById("result")!;
      const resultKicker = document.getElementById("result-kicker")!;
      const rejCount = document.getElementById("rej-count")!;
      const rejList = document.getElementById("rej-list")!;
      const regionNote = document.getElementById("region-note")!;

      const money = (n: number) => `$${n.toFixed(0)}`;
      const centsAt = (bill: number, u: number) => ((bill / u) * 100).toFixed(1);
      const esc = (s: string) =>
        s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]!);

      const KICKER: Record<Preference, string> = {
        cheapest: "Your honest cheapest plan",
        renewable: "Your honest greenest plan",
        shortest: "Your shortest honest commitment",
        lowcancel: "Your most flexible honest plan",
        rating: "Your best-rated honest plan",
      };

      function renderResult(u: number) {
        usageVal.textContent = u.toLocaleString();
        const preference = pref.value as Preference;
        resultKicker.textContent = KICKER[preference];
        const chosen = pickByPreference(data, u, preference);
        if (!chosen) {
          result.innerHTML = '<div class="empty">No honest plan is available for this usage right now.</div>';
          return;
        }
        const { pick, why, note } = chosen;
        const p = pick.plan;
        const badge = p.efl_verified
          ? '<span class="badge badge--verified">EFL-verified</span>'
          : '<span class="badge badge--estimate">feed estimate — verify EFL</span>';
        const efl = p.efl_url
          ? ` <a href="${esc(p.efl_url)}" rel="nofollow noopener" target="_blank">See the official EFL →</a>`
          : "";
        const noteHtml = note ? `<p class="pref-note">${esc(note)}</p>` : "";
        result.innerHTML = `
          <div class="plan-card">
            <div class="plan-card__top">
              <div class="plan-card__name"><span>${esc(p.rep)} — ${esc(p.product)}</span>${badge}</div>
              <div class="plan-card__rate">${centsAt(pick.monthlyBill, u)}&cent;<small>/ kWh</small></div>
            </div>
            <div class="facts">
              <div class="fact"><b>${money(pick.monthlyBill)}</b><span>est. bill</span></div>
              <div class="fact"><b>${esc(p.rate_type ?? "—")} · ${p.term_months ?? "—"} mo</b><span>rate &amp; term</span></div>
              <div class="fact"><b>${p.cancel_fee != null ? money(p.cancel_fee) : "—"}</b><span>cancel fee</span></div>
              <div class="fact"><b>${p.renewable != null ? p.renewable + "%" : "—"}</b><span>renewable</span></div>
            </div>
            <p class="why"><strong>Why this won:</strong> ${esc(why)}${efl}</p>
            ${noteHtml}
          </div>`;
      }

      const base = import.meta.env.BASE_URL;

      function renderRejected() {
        rejCount.textContent = String(data.counts.rejected);
        const shown = data.autopsies.slice(0, 12);
        let html = shown
          .map(
            (a) =>
              `<div class="rej"><span class="x" aria-label="excluded">✕</span>` +
              `<a class="pname pname-link" href="${base}plan/${encodeURIComponent(a.plan_id)}">${esc(a.rep)} — ${esc(a.product)}</a>` +
              `<span class="reason">${esc(a.verdicts[0] ?? "")}</span></div>`,
          )
          .join("");
        const extra = data.counts.rejected - shown.length;
        if (extra > 0) {
          html += `<div class="rej"><span class="x">✕</span>` +
            `<a class="pname pname-link" href="${base}rejected/${data.slug}">…and ${extra} more</a>` +
            `<span class="reason">see every rejected plan and why →</span></div>`;
        }
        rejList.innerHTML = html;
      }

      const seeAll = document.getElementById("see-all-link") as HTMLAnchorElement;
      const honestCount = document.getElementById("honest-count")!;
      const metaFor = (slug: string) => regions.find((r) => r.slug === slug);

      function updateSeeAll() {
        seeAll.href = `${base}plans/${currentSlug}`;
        honestCount.textContent = String(data.counts.honest);
      }

      function setRegionNote(source: "zip-match" | "zip-unknown" | "zip-none" | "manual", zipVal = "") {
        const m = metaFor(currentSlug);
        const label = m ? m.label : currentSlug;
        const cities = m ? m.cities : "";
        if (source === "zip-match") {
          regionNote.innerHTML = `ZIP <strong>${esc(zipVal)}</strong> → showing <strong>${esc(label)}</strong> (${esc(cities)}).`;
        } else if (source === "zip-none") {
          regionNote.innerHTML = `ZIP <strong>${esc(zipVal)}</strong> isn't in a deregulated market — that area is served by a municipal utility or co-op (like Austin Energy, CPS Energy, or El Paso Electric), so there's no retail plan to shop. We cover Oncor, CenterPoint, AEP, TNMP, and Lubbock.`;
        } else if (source === "zip-unknown") {
          regionNote.innerHTML = `We don't recognize ZIP <strong>${esc(zipVal)}</strong> as a Texas ZIP — showing <strong>${esc(label)}</strong> (${esc(cities)}). Pick your utility area above to be sure.`;
        } else {
          regionNote.innerHTML = `Showing <strong>${esc(label)}</strong> (${esc(cities)}) — chosen by area.`;
        }
      }

      // Load a region's data and re-render everything EXCEPT the status note
      // (the caller sets the note so it reflects how the region was chosen).
      async function loadRegion(slug: string): Promise<boolean> {
        if (slug !== currentSlug) {
          if (!cache[slug]) {
            try {
              const res = await fetch(`${base}data/${slug}.json`);
              if (!res.ok) throw new Error(String(res.status));
              cache[slug] = (await res.json()) as RegionData;
            } catch {
              return false; // keep the current region rather than a broken state
            }
          }
          currentSlug = slug;
          data = cache[slug];
          region.value = slug;
        }
        updateSeeAll();
        renderResult(Number(usage.value));
        renderRejected();
        return true;
      }

      usage.addEventListener("input", () => renderResult(Number(usage.value)));
      pref.addEventListener("change", () => renderResult(Number(usage.value)));

      // The ZIP and the area selector are ONE choice, never two contradictory
      // ones. A recognized ZIP drives the area; an unrecognized ZIP defers to
      // the selector (so we never show a wrong region); and choosing an area by
      // hand clears the ZIP, so the two can never disagree.
      region.addEventListener("change", async () => {
        zip.value = "";
        await loadRegion(region.value);
        setRegionNote("manual");
      });

      zip.addEventListener("input", async () => {
        const v = zip.value.trim();
        if (v.length < 5) return;
        const r = zipToSlug(v);
        if (r === null) {
          setRegionNote("zip-unknown", v);
        } else if (r === "none") {
          setRegionNote("zip-none", v);
        } else {
          await loadRegion(r);
          setRegionNote("zip-match", v);
        }
      });
    </script>
  </body>
</html>
